# Qwen Cloud / Alibaba Cloud Model Studio
# The app uses Qwen through Alibaba Cloud Model Studio's DashScope endpoint.
# Singapore default:
#   https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# US Virginia:
#   https://dashscope-us.aliyuncs.com/compatible-mode/v1
# China Beijing:
#   https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=your-qwen-cloud-api-key
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# YITING treats DASHSCOPE_API_KEY as the primary model credential.
# QWEN_API_KEY is accepted only as a backward-compatible alias.
# shared.config can populate client-library compatibility variables from those
# Qwen values at runtime.

# Optional per-role model overrides.
# Rolling Qwen Cloud aliases; use dated snapshots only after verifying
# account/region support.
QWEN_TRIAGE_MODEL=qwen3.6-flash
QWEN_DIAGNOSIS_MODEL=qwen3.7-plus
QWEN_SAFETY_MODEL=qwen3.7-plus
QWEN_COMMANDER_MODEL=qwen3.7-plus
QWEN_OPERATOR_MODEL=qwen3.6-flash

# Daily Qwen usage circuit breaker. Production Compose shares this meter across
# agent containers and fails before a live call would exceed the cap.
YITING_DAILY_TOKEN_LIMIT=250000
YITING_QWEN_USAGE_METER_PATH=/qwen-usage/yiting-qwen-usage.json

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_SECRET=generate-a-random-secret
GATEWAY_DB_PATH=yiting.db

# Agent IDs / room participant IDs
RECORDER_AGENT_ID=
TRIAGE_AGENT_ID=
DIAGNOSIS_AGENT_ID=
SAFETY_REVIEWER_AGENT_ID=
COMMANDER_AGENT_ID=
OPERATOR_AGENT_ID=

# Scribe/postmortem agent (optional)
SCRIBE_AGENT_ID=

# Optional per-agent local incident-room transport keys.
# In production prefer the role-bound *_SUBMISSION_KEY values below.
RECORDER_API_KEY=
TRIAGE_API_KEY=
DIAGNOSIS_API_KEY=
SAFETY_REVIEWER_API_KEY=
COMMANDER_API_KEY=
OPERATOR_API_KEY=

# Trusted agent IDs (comma-separated, for lookup_peers filtering)
# TRUSTED_AGENT_IDS=id1,id2,id3,id4,id5,id6

# Human approver allowlist (comma-separated approver IDs)
# MUST be set — empty allowlist rejects all approvals (fail-closed)
HUMAN_APPROVER_IDS=

# Per-agent submission keys (for role-bound Gateway auth)
# ⚠️ REQUIRED for production — each agent gets a unique key.
# Without these, agents fall back to GATEWAY_SECRET which bypasses role ACL.
# This means ANY agent could submit ANY card type (identity collapse).
# Generate unique random values for each:
RECORDER_SUBMISSION_KEY=generate-unique-key-1
TRIAGE_SUBMISSION_KEY=generate-unique-key-2
DIAGNOSIS_SUBMISSION_KEY=generate-unique-key-3
SAFETY_REVIEWER_SUBMISSION_KEY=generate-unique-key-4
COMMANDER_SUBMISSION_KEY=generate-unique-key-5
OPERATOR_SUBMISSION_KEY=generate-unique-key-6

# Approval UI (three-layer auth: Caddy basic_auth → X-Proxy-Secret → Gateway bcrypt)
# Must match the APPROVAL_PROXY_SECRET in Caddy's service environment
APPROVAL_PROXY_SECRET=generate-a-random-secret-matching-caddy
# Judge credentials for Gateway's independent bcrypt verification
APPROVAL_UI_USER=your-judge-username
APPROVAL_UI_BCRYPT_HASH=generate-with-python-bcrypt
APPROVAL_UI_APPROVER_ID=your-approver-id
APPROVAL_UI_CSRF_SECRET=generate-a-random-csrf-secret

# Victim app (for recovery verification)
VICTIM_APP_URL=http://127.0.0.1:9000

# Public Alibaba ECS URL used by demo scripts and links.
PUBLIC_BASE_URL=https://your-yiting-domain.example.com

# Practical single-VM abuse controls. The gateway keys limits by authenticated
# identity where a credential is present, otherwise by source IP.
YITING_RATE_LIMIT_PER_MINUTE=600
YITING_RATE_LIMIT_WINDOW_SECONDS=60
YITING_TRUST_PROXY_HEADERS=true

# Private recording/reset operator token. Do not publish the live value.
YITING_OPERATOR_TOKEN=generate-a-random-operator-token

# Optional manual baseline for speedup calculation (seconds).
# Set this only to a value measured for your own comparison workflow.
# Leave unset to show measured YITING timings without a speedup claim.
# MANUAL_BASELINE_SECS=

# Optional incident family for same-family speedup scoping. When set, the
# speedup denominator uses only measured runs of this family (matching the
# family the manual baseline was measured on); other aggregates are unchanged.
# BASELINE_INCIDENT_FAMILY=
