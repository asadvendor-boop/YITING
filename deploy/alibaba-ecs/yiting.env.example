# Standalone systemd path: copy to /opt/yiting/.env and fill with secrets.
# Shared-host Compose path: copy to /opt/apps/yiting/secrets/yiting.env.

DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# YITING treats DASHSCOPE_API_KEY as the primary model credential.
# QWEN_API_KEY is accepted only as a backward-compatible alias.
# shared.config.configure_openai_compatible_env() derives any client-library
# compatibility variables from these Qwen values at runtime.

# Rolling Qwen Cloud aliases tested for this submission profile. Pin dated
# snapshots after verifying account/region availability if stricter
# reproducibility is required.
QWEN_TRIAGE_MODEL=qwen3.6-flash
QWEN_DIAGNOSIS_MODEL=qwen3.7-plus
QWEN_SAFETY_MODEL=qwen3.7-plus
QWEN_COMMANDER_MODEL=qwen3.7-plus
QWEN_OPERATOR_MODEL=qwen3.6-flash

GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8000
GATEWAY_SECRET=
GATEWAY_DB_PATH=/opt/yiting/yiting.db
GATEWAY_URL=http://127.0.0.1:8000
VICTIM_APP_URL=http://127.0.0.1:9000
PUBLIC_BASE_URL=https://your-yiting-domain.example.com
YITING_RATE_LIMIT_PER_MINUTE=600
YITING_RATE_LIMIT_WINDOW_SECONDS=60
YITING_TRUST_PROXY_HEADERS=true

RECORDER_AGENT_ID=recorder
TRIAGE_AGENT_ID=triage
DIAGNOSIS_AGENT_ID=diagnosis
SAFETY_REVIEWER_AGENT_ID=safety_reviewer
COMMANDER_AGENT_ID=commander
OPERATOR_AGENT_ID=operator
SCRIBE_AGENT_ID=

RECORDER_SUBMISSION_KEY=
TRIAGE_SUBMISSION_KEY=
DIAGNOSIS_SUBMISSION_KEY=
SAFETY_REVIEWER_SUBMISSION_KEY=
COMMANDER_SUBMISSION_KEY=
OPERATOR_SUBMISSION_KEY=
INCIDENT_ROOM_API_KEY=

HUMAN_APPROVER_IDS=
APPROVAL_PROXY_SECRET=
APPROVAL_UI_USER=
APPROVAL_UI_BCRYPT_HASH=
APPROVAL_UI_APPROVER_ID=
APPROVAL_UI_CSRF_SECRET=

YITING_LIVE_CHAOS=1
NEXT_PUBLIC_YITING_MODE=live
YITING_OPERATOR_TOKEN=
