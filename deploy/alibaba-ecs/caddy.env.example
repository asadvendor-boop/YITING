[Service]
Environment=YITING_DOMAIN=your-yiting-domain.example.com
Environment=YITING_ROOT=/opt/yiting
Environment=APPROVAL_PROXY_SECRET=replace-with-the-same-value-as-yiting-env
Environment=YITING_JUDGE_USER=replace-with-judge-username
Environment=YITING_JUDGE_HASH=replace-with-approval-ui-bcrypt-hash
